#!/usr/bin/env bash
# pre-commit guard。
# staged file を取り、各 check を順次実行。
# どれか fail なら commit を block。
#
# `--no-verify` 等で bypass するのは絶対禁止 (CLAUDE.md ルール 1)。
# hook が落ちたら根本原因を直す。

set -e

FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$FILES" ]; then
  exit 0
fi

# 1. シークレット混入検査 (cortex から流用)
bash scripts/hooks/secret-check.sh $FILES

# 2. 抑制コメント禁止 (詳細は scripts/hooks/check-no-ignore.sh)
bash scripts/hooks/check-no-ignore.sh $FILES

# 3. ファイル行数上限 (コメント・空行除外、CAP=500)
pnpm exec tsx scripts/hooks/check-line-count.cli.ts $FILES

# 4. @graph-* タグ整合性
pnpm exec tsx scripts/hooks/check-graph-tags.cli.ts $FILES

# 4b. operations/log.md の古い entry が archive されているか (md 肥大化防止)
pnpm exec tsx scripts/compact-log.cli.ts --check

# 5. ESLint (max-warnings=0)
# staged TS だけ走らせる (フルプロジェクト lint は CI 側で再度走る前提)。
# `--no-warn-ignored` で ignores に該当する staged file (routeTree.gen.ts 等) の
# warning を抑止 (warning が `--max-warnings=0` を踏むのを回避)。
TS_FILES=$(echo "$FILES" | grep -E '\.(ts|tsx|js|jsx|mjs|cjs)$' || true)
if [ -n "$TS_FILES" ]; then
  pnpm exec eslint --max-warnings=0 --no-warn-ignored $TS_FILES
fi

# 6. Prettier format check (staged file のみ)
# CI が `pnpm format:check` を走らせるので、ここで弾かないと「commit は通るが CI で落ちる」事故になる。
# `--ignore-unknown` で prettier 未対応の binary / 拡張子 (例: .png, .lock) を skip、
# `--check` で diff 検出すると exit 1 → commit block。fix は `pnpm format` で。
pnpm exec prettier --check --ignore-unknown $FILES

# 7. test:coverage (per-file 90% 閾値、threshold 違反は exit 1)
pnpm exec vitest run --coverage
