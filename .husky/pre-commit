#!/usr/bin/env sh
# pre-commit guard。
#
# gate 一覧は `scripts/hooks/gates.sh` が single source of truth。
# CI workflow も同じ list を consume するので、ここに gate 漏れがあれば CI も漏れるし、
# 逆に CI を更新したら hook も自動で揃う (構造的に drift しない)。
#
# 各 gate は staged file 限定で走る (pre-commit は incremental が前提、
# フル check は CI 側 `full` mode で repo 全体を再評価する)。
#
# `--no-verify` 等で bypass するのは絶対禁止 (CLAUDE.md ルール 1)。
# hook が落ちたら根本原因を直す。
#
# 注意: husky は環境により sh / dash で実行する場合があるため、POSIX 互換で記述する
# (bash 専用構文 process substitution `<(...)` や array は使わない)。

set -e

FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$FILES" ]; then
  exit 0
fi

# gate 名を newline 区切りで取得、IFS word-split で順次実行
GATES_LIST=$(bash scripts/hooks/gates.sh list staged)
for gate in $GATES_LIST; do
  # $FILES は意図的に unquoted → space で word-split して gates.sh の positional args になる
  # shellcheck disable=SC2086
  bash scripts/hooks/gates.sh run "$gate" staged $FILES
done
