{
  "name": "self-management",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ryan's personal knowledge graph — content (X / zenn / dev.to / interviews) + decisions + topics, unified as a Product Graph scoped to a single person.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "build:force": "turbo run build --force",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm turbo run build --filter=@self/content && vitest run",
    "test:coverage": "pnpm turbo run build --filter=@self/content && vitest run --coverage",
    "typecheck": "turbo run typecheck",
    "graph:build": "pnpm --filter @self/graph-product build-graph",
    "graph:init": "pnpm --filter @self/graph-product init-bq",
    "graph:migrate": "pnpm --filter @self/graph-product migrate",
    "x:log": "pnpm --filter @self/graph-product x-log",
    "decision:add": "pnpm --filter @self/graph-product decision-add",
    "learning:add": "pnpm --filter @self/graph-product learning-add",
    "interview:add": "pnpm --filter @self/graph-product interview-add",
    "log:compact": "tsx scripts/compact-log.cli.ts",
    "log:check": "tsx scripts/compact-log.cli.ts --check",
    "covers:generate": "tsx scripts/generate-covers.cli.ts",
    "auto-review": "bash scripts/auto-review/loop.sh",
    "auto-review:once": "tsx scripts/auto-review/poll.cli.ts",
    "check:line-count": "tsx scripts/hooks/check-line-count.cli.ts",
    "check:graph-tags": "tsx scripts/hooks/check-graph-tags.cli.ts",
    "check:no-ignore": "bash scripts/hooks/check-no-ignore.sh $(git ls-files)",
    "check:secrets": "bash scripts/hooks/secret-check.sh $(git ls-files)",
    "check:all": "pnpm check:secrets && pnpm check:no-ignore && pnpm check:line-count $(git ls-files) && pnpm check:graph-tags $(git ls-files)",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@eslint/js": "catalog:",
    "@self/content": "workspace:*",
    "@self/og-image": "workspace:*",
    "@self/syndication": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "gray-matter": "catalog:",
    "husky": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
