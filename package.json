{
  "name": "self-management",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ryan's personal knowledge graph — content (X / zenn / dev.to / interviews) + decisions + topics, mirrored on the cortex Product Graph pattern but scoped to a single person.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b",
    "graph:build": "pnpm --filter @self/graph-product build-graph",
    "graph:init": "pnpm --filter @self/graph-product init-bq",
    "graph:migrate": "pnpm --filter @self/graph-product migrate",
    "check:line-count": "tsx scripts/hooks/check-line-count.ts",
    "check:graph-tags": "tsx scripts/hooks/check-graph-tags.ts",
    "check:no-ignore": "bash scripts/hooks/check-no-ignore.sh $(git ls-files)",
    "check:secrets": "bash scripts/hooks/secret-check.sh $(git ls-files)",
    "check:all": "pnpm check:secrets && pnpm check:no-ignore && pnpm check:line-count $(git ls-files) && pnpm check:graph-tags $(git ls-files)",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
