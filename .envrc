# direnv: 個人スコープの環境を自動切替
# 初回: `direnv allow` で activate

# gcloud config: 個人 (ryan-personal) に切替
export CLOUDSDK_ACTIVE_CONFIG_NAME=ryan-personal

# GCP project (Secret Manager / BQ / Vertex AI 共通)
export GOOGLE_CLOUD_PROJECT=ryan-self-management

# GCP service account credential (Pulumi で生成 → .config/ に保存)
if [ -f "$PWD/.config/gcp-sa.json" ]; then
  export GOOGLE_APPLICATION_CREDENTIALS="$PWD/.config/gcp-sa.json"
fi

# Grafana Cloud OTLP (Pulumi output から固定、token は Secret Manager から動的取得)
export OTEL_EXPORTER_OTLP_ENDPOINT="https://otlp-gateway-prod-ap-northeast-0.grafana.net/otlp"
export GRAFANA_OTLP_INSTANCE_ID="1623802"

# Pulumi passphrase (パスフレーズ式の secret 暗号化を使う場合)
if [ -f "$PWD/.config/pulumi-passphrase" ]; then
  export PULUMI_CONFIG_PASSPHRASE_FILE="$PWD/.config/pulumi-passphrase"
fi

# X (xmcp) credentials は GCP Secret Manager で管理 (apps/xmcp/secret_loader.py)。
# 旧 .config/x-automation.env / ~/.zshrc 直 export は削除済み。

# Grafana 公式 MCP server (.mcp.json) 用。Pulumi が grafana-mcp-token secret を
# 作成済み (Phase: ryan-graph MCP 拡張)。direnv 評価時に gcloud で取得して export。
# `GRAFANA_SERVICE_ACCOUNT_TOKEN` が mcp-grafana v0.13+ の正規 env (旧 GRAFANA_API_KEY
# は deprecated 警告)。
export GRAFANA_URL="https://ryantsuji.grafana.net"
if command -v gcloud >/dev/null 2>&1; then
  GRAFANA_SERVICE_ACCOUNT_TOKEN="$(gcloud secrets versions access latest --secret=grafana-mcp-token --project=ryan-self-management 2>/dev/null)"
  if [ -n "$GRAFANA_SERVICE_ACCOUNT_TOKEN" ]; then
    export GRAFANA_SERVICE_ACCOUNT_TOKEN
  fi
fi

# `.envrc.local` (gitignore 済) で個人マシン専用の env を上書き。
# ex. DATABASE_URL (Neon)、開発用の throw-away credential 等。
source_env_if_exists .envrc.local
