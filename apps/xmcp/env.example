# apps/xmcp/.env example。
#
# 本番運用 (launchd): X_USE_SECRET_MANAGER=1 で GCP Secret Manager から fetch。
# dev / test: X_USE_SECRET_MANAGER=0 にして以下を手動セット。

# Account selector (両モード共通、必須)
X_ACCOUNT=ryantsuji   # ryantsuji | ryanaircloset

# Secret Manager mode (default: 1)
X_USE_SECRET_MANAGER=1
GOOGLE_APPLICATION_CREDENTIALS=/Users/ryan/Workspace/self-management/.config/gcp-sa.json
GOOGLE_CLOUD_PROJECT=ryan-self-management

# === 以下は X_USE_SECRET_MANAGER=0 の dev mode のみ手動セット ===
# Secret Manager mode では Pulumi 管理の secret から自動投入される。

# X dev app credentials (両アカウント共通、xmcp-app-credentials secret)
X_OAUTH_CONSUMER_KEY=
X_OAUTH_CONSUMER_SECRET=
X_BEARER_TOKEN=

# OAuth2 user token 生成用 (任意、xmcp-app-credentials secret)
X_CLIENT_ID=
X_CLIENT_SECRET=

# per-user OAuth1 tokens (xmcp-user-{X_ACCOUNT} secret)
X_OAUTH_ACCESS_TOKEN=
X_OAUTH_ACCESS_TOKEN_SECRET=

# === 以下はモード共通 ===

# OAuth1 callback (initial token gen 時のみ)
X_OAUTH_CALLBACK_HOST=127.0.0.1
X_OAUTH_CALLBACK_PORT=8976
X_OAUTH_CALLBACK_PATH=/oauth/callback
X_OAUTH_CALLBACK_TIMEOUT=300

# X API
X_API_BASE_URL=https://api.x.com
X_API_TIMEOUT=30
X_API_DEBUG=1

# MCP server
MCP_HOST=127.0.0.1
MCP_PORT=8765   # ryantsuji=8765, ryanaircloset=8766

# Tool filtering (任意)
X_API_TOOL_ALLOWLIST=

# OAuth1 debug (任意)
X_OAUTH_PRINT_TOKENS=
X_OAUTH_PRINT_AUTH_HEADER=
