{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ryantsuji-dev-web",
  // `@cloudflare/vite-plugin` が ssr environment を Worker bundle に変換し、`src/server.ts`
  // (= `tanstackStart({ server: { entry } })` で指定) を default export として解決する。
  // 直接 dist パスを書かないことで build 出力構造の変更に追従する (SKILL 推奨パターン)。
  "main": "./src/server.ts",
  "compatibility_date": "2025-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "routes": [
    { "pattern": "ryantsuji.dev", "custom_domain": true },
    { "pattern": "www.ryantsuji.dev", "custom_domain": true },
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
  },
}
