{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ryantsuji-dev-web",
  // `@cloudflare/vite-plugin` が ssr environment を Worker bundle に変換し、`src/server.ts`
  // (= `tanstackStart({ server: { entry } })` で指定) を default export として解決する。
  // 直接 dist パスを書かないことで build 出力構造の変更に追従する (SKILL 推奨パターン)。
  "main": "./src/server.ts",
  "compatibility_date": "2025-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "routes": [
    { "pattern": "ryantsuji.dev", "custom_domain": true },
    { "pattern": "www.ryantsuji.dev", "custom_domain": true },
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
  // 自前 analytics の BQ 書き込み先。値が public で問題ないため secret ではなく vars。
  // `GCP_SA_JSON` (SA JSON key)、`OTLP_*` (Grafana Cloud) は `wrangler secret put` 別途。
  "vars": {
    "BQ_PROJECT_ID": "ryan-self-management",
    "BQ_DATASET": "ryan",
    "BQ_TABLE": "web_events",
  },
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
  },
  // R2 bucket binding。post 添付画像の配信元 (`/images/*` route で `env.IMAGES.get`)。
  // bucket 自体は `infra/ryantsuji-dev/index.ts` の Pulumi で declarative 管理、画像
  // ファイル本体は `scripts/sync-r2-images.cli.ts` が CI deploy 直前に R2 へ sync する。
  "r2_buckets": [
    {
      "binding": "IMAGES",
      "bucket_name": "ryantsuji-dev-images",
    },
  ],
}
