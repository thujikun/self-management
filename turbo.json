{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["pnpm-lock.yaml", "pnpm-workspace.yaml", "tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "vite-plugins/**",
        "vite.config.ts",
        "vitest.config.ts",
        "tsconfig.json",
        "package.json",
        "tsconfig.base.json"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
