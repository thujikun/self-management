{
  "name": "@self/db",
  "version": "0.1.0",
  "private": true,
  "description": "ryantsuji.dev DB schema (Drizzle + Neon) — comments, likes, view counts, sessions",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "tsgo",
    "typecheck": "tsgo --noEmit",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:studio": "drizzle-kit studio",
    "migrate:apply": "tsx scripts/apply-migrations.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "catalog:",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "tsx": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
